# Turso (SQLite) database
# - Local dev: use a file URL, no token needed: TURSO_DATABASE_URL=file:./local.db
# - Production: sign up at https://turso.tech, then `turso db create aluna`
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Admin authentication
ADMIN_PASSWORD=change-me
ADMIN_COOKIE_SECRET=run-`openssl rand -hex 32`-to-generate

# WhatsApp number that receives orders.
# Digits only, with country code, no + (e.g. 5215512345678 for MX).
# Note: rendered to clients in wa.me links — it is NOT a secret.
WHATSAPP_PHONE=

# Optional: allow local dev to read production Netlify Blobs when the database
# contains /api/images/* records created in production.
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=
