---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AdminNav from '../../../components/AdminNav.astro';
import { listProductos } from '../../../lib/products';
import { formatMXN } from '../../../lib/money';
import styles from '../admin.module.css';

export const prerender = false;

const productos = await listProductos({ includeUnavailable: true });
---
<BaseLayout title="Productos — admin" showChrome={false}>
  <div class={styles.page}>
    <AdminNav active="productos" />
    <div class={styles.pageHead}>
      <h1 class={styles.pageTitle}>Productos</h1>
      <a class={styles.newBtn} href="/admin/productos/nuevo">+ Nuevo</a>
    </div>

    {productos.length === 0 ? (
      <p style="color: var(--text-muted); text-align: center; padding: var(--s-10)">
        Aún no hay productos. <a href="/admin/productos/nuevo" style="text-decoration: underline">Crear el primero</a>.
      </p>
    ) : (
      <table class={styles.table}>
        <thead>
          <tr>
            <th class={styles.thumbCell}></th>
            <th>Nombre</th>
            <th>SKU</th>
            <th>Precio</th>
            <th>Estado</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {productos.map((p) => (
            <tr data-row-slug={p.slug}>
              <td class={styles.thumbCell}>
                {p.imagenes[0] && (
                  <img class={styles.thumb} src={p.imagenes[0].url} alt={p.nombre} loading="lazy" />
                )}
              </td>
              <td>
                <a href={`/admin/productos/${p.slug}`} style="text-decoration: underline">{p.nombre}</a>
                <div style="color: var(--text-muted); font-size: var(--fs-xs)">{p.slug}</div>
              </td>
              <td style="font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: var(--fs-xs)">
                {p.sku ?? '—'}
              </td>
              <td>{formatMXN(p.precio)}</td>
              <td>
                <span
                  data-badge
                  data-cls-on={styles.badgeEntregado}
                  data-cls-off={styles.badgeCancelado}
                  class:list={[styles.badge, p.disponible ? styles.badgeEntregado : styles.badgeCancelado]}
                >
                  {p.disponible ? 'Disponible' : 'Oculto'}
                </span>
              </td>
              <td style="text-align: right">
                <form
                  method="POST"
                  action={`/api/admin/products/${p.slug}/toggle`}
                  data-toggle-form
                  style="display: inline"
                >
                  <button type="submit" class={styles.toggleBtn} data-toggle-btn>
                    {p.disponible ? 'Ocultar' : 'Mostrar'}
                  </button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-toggle-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector<HTMLButtonElement>('[data-toggle-btn]');
      const badge = form.closest('tr')?.querySelector<HTMLElement>('[data-badge]');
      if (!btn || !badge) return;

      const clsOn = badge.dataset.clsOn ?? '';
      const clsOff = badge.dataset.clsOff ?? '';

      btn.disabled = true;
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = (await res.json()) as { ok: boolean; disponible: boolean };
        if (!data.ok) throw new Error('no-ok');
        btn.textContent = data.disponible ? 'Ocultar' : 'Mostrar';
        badge.textContent = data.disponible ? 'Disponible' : 'Oculto';
        badge.classList.remove(data.disponible ? clsOff : clsOn);
        badge.classList.add(data.disponible ? clsOn : clsOff);
      } catch {
        // Fall back to full reload if the AJAX path breaks.
        window.location.reload();
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>
