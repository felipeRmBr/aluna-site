---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AdminNav from '../../../components/AdminNav.astro';
import { listProductLines } from '../../../lib/productLines';
import styles from '../admin.module.css';

export const prerender = false;

const productLines = await listProductLines();
---
<BaseLayout title="Líneas de producto — admin" showChrome={false}>
  <div class={styles.page}>
    <AdminNav active="product-lines" />
    <div class={styles.pageHead}>
      <h1 class={styles.pageTitle}>Líneas de producto</h1>
      <a class={styles.newBtn} href="/admin/product-lines/nueva">+ Nueva</a>
    </div>

    {productLines.length === 0 ? (
      <p style="color: var(--text-muted); text-align: center; padding: var(--s-10)">
        Aún no hay líneas de producto. <a href="/admin/product-lines/nueva" style="text-decoration: underline">Crear la primera</a>.
      </p>
    ) : (
      <table class={styles.table}>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Orden</th>
            <th>Colores</th>
          </tr>
        </thead>
        <tbody>
          {productLines.map((v) => (
            <tr onclick={`location.href='/admin/product-lines/${v.slug}'`}>
              <td>
                <a href={`/admin/product-lines/${v.slug}`} style="text-decoration: underline">{v.nombre}</a>
                <div style="color: var(--text-muted); font-size: var(--fs-xs)">{v.slug}</div>
              </td>
              <td>{v.orden}</td>
              <td>{v.colores.length}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</BaseLayout>
