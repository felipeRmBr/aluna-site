---
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ProductGallery from '../../components/islands/ProductGallery.tsx';
import { formatMXN } from '../../lib/money';
import { getProducto, listProductos } from '../../lib/products';
import { getColeccion } from '../../lib/colecciones';
import styles from './detail.module.css';
import pageStyles from '../../styles/page.module.css';

export const prerender = false;

const { slug } = Astro.params;
const producto = slug ? await getProducto(slug) : null;
if (!producto) return Astro.redirect('/404');

const colsResueltas = (
  await Promise.all(producto.colecciones.map((s) => getColeccion(s)))
).filter((c): c is NonNullable<typeof c> => Boolean(c));

const descripcionHtml = producto.descripcionMd
  ? marked.parse(producto.descripcionMd, { async: false })
  : null;

const galleryImages = producto.imagenes.map((img, i) => ({
  url: img.url,
  alt: `${producto.nombre} — vista ${i + 1}`,
}));

const allProductos = await listProductos();
const activeColorCombinaciones = producto.colorCombinaciones.filter((combo) => combo.activo);
const otrosProductos = (() => {
  const others = allProductos.filter((p) => p.slug !== producto.slug);
  const sameCollection = others.filter((p) =>
    p.colecciones.some((c) => producto.colecciones.includes(c)),
  );
  const rest = others.filter(
    (p) => !p.colecciones.some((c) => producto.colecciones.includes(c)),
  );
  return [...sameCollection, ...rest].slice(0, 4);
})();
---
<BaseLayout title={`${producto.nombre} — ALUNA`} description={producto.descripcionCorta}>
  <article class={styles.wrap}>
    <div class={styles.main}>
      <ProductGallery client:load images={galleryImages} nombre={producto.nombre} />

      <div class={styles.info}>
      {colsResueltas.length > 0 && (
        <p class={styles.crumbs}>
          {colsResueltas.map((c, i) => {
            const isLast = i === colsResueltas.length - 1;
            return (
              <Fragment>
                <a href={`/colecciones/${c.slug}`}>{c.nombre}</a>
                {!isLast && <span> · </span>}
              </Fragment>
            );
          })}
        </p>
      )}

      <h1 class={styles.name}>{producto.nombre}</h1>
      <p class={styles.price}>{formatMXN(producto.precio)}</p>
      <p class={styles.desc}>{producto.descripcionCorta}</p>

      {descripcionHtml && (
        <div class={styles.body} set:html={descripcionHtml} />
      )}

      {activeColorCombinaciones.length > 0 && (
        <fieldset class={styles.colorPicker}>
          <legend class={styles.colorLegend}>Color</legend>
          <div class={styles.colorOptions}>
            {activeColorCombinaciones.map((combo) => (
              <label class={styles.colorOption}>
                <input
                  type="radio"
                  name="color-combination"
                  value={combo.id}
                  data-color-combination-option
                  data-color-combination-name={combo.nombre}
                />
                <span>
                  <span class={styles.colorSwatches}>
                    {combo.colores.map((color) => (
                      <span
                        class={styles.colorSwatch}
                        style={color.hex ? `background: ${color.hex}` : undefined}
                        title={color.nombre}
                      >
                        {!color.hex && color.nombre.slice(0, 1)}
                      </span>
                    ))}
                  </span>
                  <span>{combo.nombre}</span>
                </span>
              </label>
            ))}
          </div>
          <p class={styles.colorRequired} data-color-required-message hidden>
            Elige una combinación de color para continuar.
          </p>
        </fieldset>
      )}

      <button
        class={styles.addBtn}
        type="button"
        data-add-to-cart
        data-available={producto.disponible ? 'true' : 'false'}
        data-requires-color={activeColorCombinaciones.length > 0 ? 'true' : 'false'}
        data-slug={producto.slug}
        data-nombre={producto.nombre}
        data-precio={producto.precio}
        data-imagen={producto.imagenes[0]?.url ?? ''}
        disabled={!producto.disponible || activeColorCombinaciones.length > 0}
      >
        {producto.disponible ? 'Añadir al carrito' : 'Agotado'}
      </button>

      {producto.sku && <p class={styles.sku}>SKU: {producto.sku}</p>}
      </div>
    </div>

    {otrosProductos.length > 0 && (
      <section class={styles.related}>
        <header class={pageStyles.sectionHead}>
          <p class={pageStyles.eyebrow}>Explorar</p>
          <h2 class={pageStyles.sectionTitle}>Otros productos</h2>
        </header>
        <div class={pageStyles.productGrid}>
          {otrosProductos.map((p) => (
            <ProductCard
              slug={p.slug}
              nombre={p.nombre}
              precio={p.precio}
              imagen={p.imagenes[0]?.url ?? null}
              disponible={p.disponible}
              hasColorCombinations={p.colorCombinaciones.some((combo) => combo.activo)}
            />
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
<script>
  const addBtn = document.querySelector<HTMLButtonElement>('[data-add-to-cart]');
  const colorMessage = document.querySelector<HTMLElement>('[data-color-required-message]');

  document.querySelectorAll<HTMLInputElement>('[data-color-combination-option]').forEach((input) => {
    input.addEventListener('change', () => {
      if (!addBtn || !input.checked) return;
      addBtn.dataset.colorCombinationId = input.value;
      addBtn.dataset.colorCombinationNombre = input.dataset.colorCombinationName ?? '';
      addBtn.disabled = addBtn.dataset.available !== 'true';
      if (colorMessage) colorMessage.hidden = true;
    });
  });
</script>

