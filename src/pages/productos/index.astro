---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { listProductos } from '../../lib/products';
import styles from '../../styles/page.module.css';

export const prerender = false;

const productos = await listProductos();
---
<BaseLayout title="Productos — ALUNA">
  <section class={styles.section}>
    <header class={styles.sectionHead}>
      <p class={styles.eyebrow}>Catálogo</p>
      <h1 class={styles.sectionTitle}>Todos los productos</h1>
    </header>
    <div class={styles.productGrid}>
      {productos.map((p) => (
        <ProductCard
          slug={p.slug}
          nombre={p.nombre}
          precio={p.precio}
          imagen={p.imagenes[0]?.url ?? null}
          disponible={p.disponible}
          hasColorCombinations={p.colorCombinaciones.some((combo) => combo.activo)}
        />
      ))}
    </div>
  </section>
</BaseLayout>
