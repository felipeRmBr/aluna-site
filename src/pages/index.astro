---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { listProductos } from '../lib/products';
import { listColecciones } from '../lib/colecciones';
import { img } from '../lib/img';
import styles from '../styles/page.module.css';

export const prerender = false;

const productos = await listProductos();
const colecciones = await listColecciones({ destacadasOnly: true });

const destacados = productos.slice(0, 6);
---
<BaseLayout>
  <section class={styles.hero}>
    <p class={styles.eyebrow}>Lookbook 2026</p>
    <h1 class={styles.heroTitle}>ALUNA</h1>
    <p class={styles.heroSub}>Pequeños detalles, grandes espacios.</p>
    <a class={styles.heroCta} href="/colecciones">Ver colecciones</a>
  </section>

  {colecciones.length > 0 && (
    <section class={styles.section}>
      <header class={styles.sectionHead}>
        <p class={styles.eyebrow}>Colecciones</p>
        <h2 class={styles.sectionTitle}>Destacadas</h2>
      </header>
      <div class={styles.colsGrid}>
        {colecciones.map((c) => (
          <a class={styles.colCard} href={`/colecciones/${c.slug}`}>
            <div class={styles.colMedia}>
              {c.hero && <img src={img(c.hero, { w: 800, fit: 'cover', fm: 'webp', q: 80 })} alt={c.nombre} loading="lazy" />}
            </div>
            <span class={styles.colName}>{c.nombre}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class={styles.section}>
    <header class={styles.sectionHead}>
      <p class={styles.eyebrow}>Productos</p>
      <h2 class={styles.sectionTitle}>Esenciales</h2>
    </header>
    <div class={styles.productGrid}>
      {destacados.map((p) => (
        <ProductCard
          slug={p.slug}
          nombre={p.nombre}
          precio={p.precio}
          imagen={p.imagenes[0]?.url ?? null}
          disponible={p.disponible}
        />
      ))}
    </div>
  </section>
</BaseLayout>
