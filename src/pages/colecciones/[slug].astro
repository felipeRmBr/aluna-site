---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getColeccion } from '../../lib/colecciones';
import { listProductos } from '../../lib/products';
import styles from '../../styles/page.module.css';

export const prerender = false;

const { slug } = Astro.params;
const coleccion = slug ? await getColeccion(slug) : null;
if (!coleccion) return Astro.redirect('/404');

const productos = await listProductos({ coleccion: coleccion.slug });
---
<BaseLayout title={`${coleccion.nombre} — ALUNA`} description={coleccion.descripcion}>
  <section class={styles.section}>
    <header class={styles.sectionHead}>
      <p class={styles.eyebrow}>Colección</p>
      <h1 class={styles.sectionTitle}>{coleccion.nombre}</h1>
      <p style="max-width: 600px; color: var(--text-muted); margin-top: var(--s-2)">
        {coleccion.descripcion}
      </p>
    </header>
    {productos.length === 0 ? (
      <p style="text-align: center; color: var(--text-muted)">No hay productos en esta colección todavía.</p>
    ) : (
      <div class={styles.productGrid}>
        {productos.map((p) => (
          <ProductCard
            slug={p.slug}
            nombre={p.nombre}
            precio={p.precio}
            imagen={p.imagenes[0]?.url ?? null}
            disponible={p.disponible}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
