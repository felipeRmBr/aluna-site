---
type Props = { size?: number; class?: string };
const { size = 22, class: className } = Astro.props;
---
<a href="/" class:list={['logo', className]} aria-label="ALUNA — inicio">
  <span class="word" style={`font-size:${size}px`}>ALUNA</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text);
  }
  .word {
    font-family: var(--font-display);
    letter-spacing: var(--tracking-display);
    font-weight: 400;
    line-height: 1;
  }
</style>
